# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Local development (Docker or local Postgres)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"

# Supabase (use this in production)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# JWT / AUTH
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-minimum-64-char-random-secret-generated-with-openssl"
JWT_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# NETOPIA PAYMENTS
# ─────────────────────────────────────────────
# Set to "true" for sandbox, "false" for production
NETOPIA_SANDBOX="true"

# Your Netopia merchant POSID (from Netopia admin panel)
NETOPIA_POSID="your-netopia-posid"

# API signature key (from Netopia admin panel)
NETOPIA_API_KEY="your-netopia-api-key"

# RSA public key certificate (PEM format) - provided by Netopia
NETOPIA_PUBLIC_KEY_PATH="./certs/netopia-public.cer"

# RSA private key (PEM format) - generated by you, public key uploaded to Netopia
NETOPIA_PRIVATE_KEY_PATH="./certs/netopia-private.key"

# The full URL Netopia will POST payment notifications to (must be publicly accessible)
NETOPIA_IPN_URL="https://yourdomain.com/api/payments/netopia/ipn"

# Where Netopia redirects the customer after a successful payment
NETOPIA_RETURN_URL="https://yourdomain.com/payment/return"

# Where Netopia redirects the customer if they cancel the payment
NETOPIA_CANCEL_URL="https://yourdomain.com/payment/cancel"

# ─────────────────────────────────────────────
# APP / BUSINESS SETTINGS
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Origin allowed by CORS (the frontend URL). Use * to allow all origins.
FRONTEND_URL="http://localhost:3001"

# ─────────────────────────────────────────────
# SUPABASE STORAGE (for image uploads)
# ─────────────────────────────────────────────
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# Shipping cost in RON (as an integer or decimal string)
SHIPPING_COST_RON="25"

# Orders above this amount get free shipping (set to 0 to disable)
FREE_SHIPPING_THRESHOLD_RON="250"

# ─────────────────────────────────────────────
# EMAIL (optional — mocked if not set)
# ─────────────────────────────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@yourdomain.com"
# SMTP_PASS="your-smtp-password"
# EMAIL_FROM="SD Beauty Hub <noreply@yourdomain.com>"
